code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled;

uniform float edge_mult = 0.75;
uniform float edge_add = 0.40000000596046;
uniform sampler2D Color_Gradient : source_color, hint_default_black, repeat_disable;



void fragment() {
// Input:2
	vec3 n_out2p0 = CAMERA_DIRECTION_WORLD;


// Input:8
	mat4 n_out8p0 = VIEW_MATRIX;


// Input:3
	vec3 n_out3p0 = NORMAL;


// TransformVectorMult:9
	vec3 n_out9p0 = (vec4(n_out3p0, 1.0) * n_out8p0).xyz;


// DotProduct:4
	float n_out4p0 = dot(n_out2p0, n_out9p0);


// FloatParameter:16
	float n_out16p0 = edge_mult;


// FloatParameter:17
	float n_out17p0 = edge_add;


// MultiplyAdd:13
	float n_out13p0 = fma(n_out4p0, n_out16p0, n_out17p0);


// FloatOp:14
	float n_in14p0 = 1.00000;
	float n_out14p0 = n_in14p0 - n_out13p0;


// Clamp:15
	float n_in15p1 = 0.00000;
	float n_in15p2 = 1.00000;
	float n_out15p0 = clamp(n_out14p0, n_in15p1, n_in15p2);


	vec4 n_out6p0;
// Texture2D:6
	n_out6p0 = texture(Color_Gradient, vec2(n_out15p0));


// VectorDecompose:18
	float n_out18p0 = n_out6p0.x;
	float n_out18p1 = n_out6p0.y;
	float n_out18p2 = n_out6p0.z;
	float n_out18p3 = n_out6p0.w;


// Output:0
	ALBEDO = vec3(n_out6p0.xyz);
	ALPHA = n_out18p3;


}
"
